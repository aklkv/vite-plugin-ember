{
  "name": "vite-plugin-ember",
  "version": "0.8.1",
  "description": "VitePress plugin for live, interactive Ember components in your documentation — write .gjs/.gts in markdown and see them render",
  "license": "MIT",
  "type": "module",
  "author": "Alexey Kulakov",
  "homepage": "https://github.com/aklkv/vite-plugin-ember#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aklkv/vite-plugin-ember.git",
    "directory": "vite-plugin-ember"
  },
  "bugs": {
    "url": "https://github.com/aklkv/vite-plugin-ember/issues"
  },
  "keywords": [
    "vitepress",
    "vitepress-plugin",
    "vite",
    "vite-plugin",
    "ember",
    "emberjs",
    "ember-source",
    "ember-modifier",
    "glimmer",
    "glimmer-component",
    "template-tag",
    "gjs",
    "gts",
    "documentation",
    "docs",
    "live-preview",
    "playground"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components/CodePreview": {
      "types": "./dist/vitepress/code-preview.d.ts",
      "default": "./dist/vitepress/code-preview.js"
    },
    "./owner": {
      "types": "./dist/vitepress/create-owner.d.ts",
      "default": "./dist/vitepress/create-owner.js"
    },
    "./setup": {
      "types": "./dist/vitepress/setup.d.ts",
      "default": "./dist/vitepress/setup.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "concurrently 'pnpm:lint:*(!fix)' --names 'lint:'",
    "lint:fix": "concurrently 'pnpm:lint:*:fix' --names 'fix:'",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:format": "prettier . --cache --check",
    "lint:format:fix": "prettier . --cache --write",
    "lint:types": "tsc --noEmit",
    "format": "prettier . --cache --write",
    "format:check": "prettier . --cache --check"
  },
  "dependencies": {
    "decorator-transforms": "^2.4.0",
    "ember-live-compiler": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.1",
    "concurrently": "^10.0.3",
    "ember-source": "7.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "markdown-it": "^14.2.0",
    "markdown-it-async": "^2.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vitepress": "^1.6.4",
    "vue": "^3.5.39"
  },
  "peerDependencies": {
    "@glimmer/component": ">=1",
    "ember-source": ">=6.12.0",
    "vite": ">=5",
    "vitepress": ">=1 || >=2.0.0-alpha",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "@glimmer/component": {
      "optional": true
    }
  }
}
